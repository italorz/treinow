# Dependências e artefatos (regeneráveis no build)
app/vendor/
app/node_modules/
app/public/build/
app/public/hot
app/public/storage

# Ambiente e segredos
app/.env
app/.env.backup
app/.env.production

# Banco local de desenvolvimento (o container cria o seu)
app/database/database.sqlite

# Logs e caches
app/storage/logs/*
!app/storage/logs/.gitignore
app/storage/framework/cache/*
app/storage/framework/sessions/*
app/storage/framework/views/*
app/.phpunit.result.cache

# Diversos
.DS_Store
Thumbs.db
scratchpad/
